```dotenv
# ==============================================================================
# Application Configuration
# ==============================================================================
APP_NAME=customer-churn-mlops
APP_ENV=development
APP_VERSION=0.1.0

# Logging
LOG_LEVEL=INFO

# ==============================================================================
# MLflow Configuration
# ==============================================================================
MLFLOW_HOST=13.234.232.42
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://13.234.232.42:5000

# ==============================================================================
# AWS Configuration
# ==============================================================================
AWS_REGION=ap-south-1

# These values will be populated when we provision AWS resources.
S3_BUCKET=
ECR_REPOSITORY=

# ==============================================================================
# Model Configuration
# ==============================================================================
MODEL_NAME=customer-churn-model
MODEL_VERSION=1

# ==============================================================================
# API Configuration
# ==============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# ==============================================================================
# Future Configurations (Keep Empty for Now)
# ==============================================================================
DATABASE_URL=
REDIS_URL=
PROMETHEUS_ENABLED=false
```
